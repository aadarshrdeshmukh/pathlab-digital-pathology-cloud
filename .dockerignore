# Ignore local dependencies
node_modules/
backend/node_modules/
frontend/node_modules/

# Ignore Next.js builds
frontend/.next/

# Ignore logs
logs/
*.log

# Ignore environment files and configs
.env
backend/.env
frontend/.env

# Ignore OS metadata
.DS_Store
Thumbs.db

# Ignore Git files
.git/
.gitignore

# Ignore local uploads fallback
backend/uploads/*
!backend/uploads/sample_report.pdf
